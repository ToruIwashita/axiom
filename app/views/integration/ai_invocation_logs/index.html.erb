<% content_for :title, "AI Invocation Logs" %>

<h1>AI Invocation Logs</h1>

<%# フィルタフォーム %>
<div style="margin-bottom: 1.5em; padding: 1em; background: #f5f5f5; border-radius: 4px;">
  <%= form_with url: integration_ai_invocation_logs_path, method: :get, local: true do |f| %>
    <%= f.label :context_type, "Context Type:" %>
    <%= f.select :context_type, options_for_select([["(全て)", ""]] + @context_types.map { |ct| [ct, ct] }, @selected_context_type) %>

    <%= f.label :status, "Status:" %>
    <%= f.select :status, options_for_select([["(全て)", ""]] + @statuses.map { |st| [st, st] }, @selected_status) %>

    <%= f.submit "絞り込み" %>
    <%= link_to "リセット", integration_ai_invocation_logs_path, style: "margin-left: 1em;" %>
  <% end %>
</div>

<%# 件数表示 %>
<p style="color: #666;">全 <%= @logs.total_count %> 件 / 表示 <%= @logs.size %> 件</p>

<% if @logs.any? %>
  <table border="1" cellpadding="6" cellspacing="0" style="border-collapse: collapse; width: 100%;">
    <thead style="background: #eee;">
      <tr>
        <th>ID</th>
        <th>Context Type</th>
        <th>Status</th>
        <th>Latency (ms)</th>
        <th>Created At</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @logs.each do |log| %>
        <tr>
          <td><%= log.id %></td>
          <td><%= log.context_type %></td>
          <td><%= render "status_badge", log: log %></td>
          <td><%= log.latency_ms %></td>
          <td><%= log.created_at.iso8601 %></td>
          <td><%= link_to "詳細", integration_ai_invocation_log_path(log) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%# kaminari ページネーション %>
  <div style="margin-top: 1em;">
    <%= paginate @logs %>
  </div>
<% else %>
  <p style="color: #666;">該当する AI 呼び出しログが存在しません。</p>
<% end %>
