<% if flash[:alert] %>
  <div class="alert"><%= flash[:alert] %></div>
<% end %>

<%= form_with model: definition, url: url, method: method, local: true do |f| %>
  <div>
    <%= f.label :name, "名前" %>
    <%= f.text_field :name, required: true %>
  </div>
  <div>
    <%= f.label :description, "説明" %>
    <%= f.text_area :description, rows: 3 %>
  </div>
  <div>
    <%= f.label :market_type, "市場区分" %>
    <%= f.select :market_type, [ ["futures", "futures"], ["spot", "spot"] ] %>
  </div>
  <div>
    <%= f.submit %>
  </div>
<% end %>
