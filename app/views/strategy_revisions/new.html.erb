<% content_for :title, "新規 Revision 作成 - #{@definition.name}" %>

<h1>新規 Revision 作成 - <%= @definition.name %></h1>

<% if flash[:alert] %>
  <div class="alert"><%= flash[:alert] %></div>
<% end %>

<%= form_with url: strategy_definition_revisions_path(@definition), method: :post, local: true do |f| %>
  <div>
    <label>script_entrypoint</label>
    <%= f.text_field "strategy_revision[script_entrypoint]", value: @revision_form[:script_entrypoint], required: true %>
    <small>例: MyStrategy(eval 後にインスタンス化するクラス名)</small>
  </div>
  <div>
    <label>script_content</label>
    <%= f.text_area "strategy_revision[script_content]", value: @revision_form[:script_content], rows: 12, cols: 80, required: true %>
    <small>Domain::TradingScriptBase を継承した戦略 Ruby コード</small>
  </div>
  <hr>
  <h3>AI フィルタ設定</h3>
  <div>
    <label>
      <%= f.check_box "strategy_revision[ai_filter_enabled]", { checked: @revision_form[:ai_filter_enabled] }, "1", "0" %>
      AI フィルタを有効化
    </label>
  </div>
  <div>
    <label>ai_filter_template_name</label>
    <%= f.text_field "strategy_revision[ai_filter_template_name]", value: @revision_form[:ai_filter_template_name] %>
  </div>
  <div>
    <label>ai_filter_fail_safe</label>
    <%= f.select "strategy_revision[ai_filter_fail_safe]", [ ["skip", "skip"], ["proceed", "proceed"] ], { selected: @revision_form[:ai_filter_fail_safe] } %>
  </div>
  <div>
    <label>ai_filter_timeout_sec</label>
    <%= f.number_field "strategy_revision[ai_filter_timeout_sec]", value: @revision_form[:ai_filter_timeout_sec], min: 1 %>
  </div>
  <hr>
  <h3>AI サイジング</h3>
  <div>
    <label>
      <%= f.check_box "strategy_revision[ai_sizing_enabled]", { checked: @revision_form[:ai_sizing_enabled] }, "1", "0" %>
      AI サイジングを有効化
    </label>
  </div>
  <hr>
  <%= f.submit "Draft として作成" %>
<% end %>

<p><%= link_to "戦略定義詳細へ", strategy_definition_path(@definition) %></p>
